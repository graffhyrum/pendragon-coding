diff --git a/dist/index.d.mts b/dist/index.d.mts
index 1a0addc028583967d5b3a3e6249674f2df231350..3ea52027523bbc10207acca3a4e92bb4cd84c46c 100644
--- a/dist/index.d.mts
+++ b/dist/index.d.mts
@@ -1,8 +1,28 @@
 import { SerialFrameSelector, RunOptions, AxeResults } from 'axe-core';
-import { Page } from 'playwright-core';
+import type { Page } from 'playwright-core';
+
+/** Minimal Page shape used by AxeBuilder; accepts Page from any playwright-core resolution (avoids duplicate type-root errors with @playwright/test). */
+interface AxeBuilderPage {
+	evaluate<T>(expression: ((arg: unknown) => T) | string, arg?: unknown): Promise<T>;
+	mainFrame(): unknown;
+	frames(): unknown[];
+	context(): unknown;
+}
+
+/** Subset of Page that AxeBuilder uses; if Playwright removes/changes these, the assertion below errors. */
+type PageSubsetUsedByAxeBuilder = Pick<
+	Page,
+	'evaluate' | 'mainFrame' | 'frames' | 'context'
+>;
+type Assert<T extends true> = T;
+/** Fails to compile if playwright-core Page no longer has the subset AxeBuilder uses. */
+type _AssertPageSubsetStillCompatible = Assert<
+	PageSubsetUsedByAxeBuilder extends AxeBuilderPage ? true : false
+>;
+declare const _assertPageCompatible: _AssertPageSubsetStillCompatible;
 
 interface AxePlaywrightParams {
-    page: Page;
+    page: AxeBuilderPage;
     axeSource?: string;
 }
 
