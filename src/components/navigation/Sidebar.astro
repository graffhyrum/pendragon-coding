---
import { toSlug } from '../../utils/slugify';

interface Props {
	sections: Array<{
		title: string;
		content: Array<{
			title: string;
			link: Array<{ title?: string; href: string }>;
		}>;
	}>;
}

const { sections } = Astro.props;
---

<aside
	class="sidebar w-64 sticky top-8 overflow-y-auto bg-green-50 dark:bg-emerald-900 border border-green-300 dark:border-green-700 rounded-lg p-6 mr-8 max-md:fixed max-md:inset-y-0 max-md:left-0 max-md:h-screen max-md:w-80 max-md:max-h-screen max-md:z-40 max-md:-translate-x-full max-md:transition-transform max-md:duration-300 max-md:mr-0 max-md:rounded-none max-md:border-l-0 max-md:border-t-0 max-md:border-b-0 [&.open]:max-md:translate-x-0"
	aria-label="Section navigation"
>
	<nav>
		<h3 class="text-lg font-semibold text-green-900 dark:text-green-100 mb-4 border-b-2 border-green-600 dark:border-green-400 pb-2">Sections</h3>
		<ul class="list-none p-0 m-0">
			{sections.map((section) => {
				const sectionId = toSlug(section.title);
				return (
					<li>
						<a
							href={`#${sectionId}`}
							class="section-link block py-2 px-3 text-green-800 dark:text-green-200 no-underline rounded transition-all duration-200 border-l-[3px] border-transparent hover:bg-green-200 hover:text-green-900 hover:border-l-green-600 dark:hover:bg-green-950 dark:hover:text-green-100 dark:hover:border-l-green-400 focus:outline-2 focus:outline-green-600 focus:outline-offset-2 data-[active=true]:bg-green-700 data-[active=true]:text-white data-[active=true]:border-l-green-900 dark:data-[active=true]:bg-green-700 dark:data-[active=true]:text-white dark:data-[active=true]:border-l-green-400"
							data-section={sectionId}
						>
							{section.title}
						</a>
						{section.content.length > 0 && (
							<ul class="list-none p-0 mt-2 ml-4">
								{section.content.map((item) => {
									const contentId = `${sectionId}-${toSlug(item.title)}`;
									return (
										<li>
											<a
												href={`#${contentId}`}
												class="content-link block py-1 px-2 text-green-800 dark:text-green-400 no-underline rounded transition-all duration-200 text-sm border-l-2 border-transparent hover:bg-green-100 hover:text-green-800 hover:border-l-green-500 dark:hover:bg-emerald-900 dark:hover:text-green-300 dark:hover:border-l-green-400 focus:outline-1 focus:outline-green-500 focus:outline-offset-1 data-[active=true]:bg-green-700 data-[active=true]:text-white data-[active=true]:border-l-green-700 dark:data-[active=true]:bg-green-400 dark:data-[active=true]:text-emerald-900 dark:data-[active=true]:border-l-green-300"
												data-content={contentId}
												title={item.title}
											>
												{item.title}
											</a>
										</li>
									);
								})}
							</ul>
						)}
					</li>
				);
			})}
		</ul>
	</nav>

	<!-- Mobile menu button -->
	<button
		class="sidebar-toggle hidden max-md:block fixed top-4 left-4 z-50 bg-green-600 border-0 rounded p-2 cursor-pointer"
		aria-label="Toggle sidebar"
		aria-expanded="false"
	>
		<span class="hamburger"></span>
	</button>
</aside>

<style>
	/* Hamburger animation — pseudo-elements require CSS */
	.hamburger {
		display: block;
		width: 1.5rem;
		height: 2px;
		background: white;
		position: relative;
		transition: all 0.3s ease;
	}

	.hamburger::before,
	.hamburger::after {
		content: '';
		position: absolute;
		width: 1.5rem;
		height: 2px;
		background: white;
		transition: all 0.3s ease;
	}

	.hamburger::before {
		top: -0.5rem;
	}

	.hamburger::after {
		top: 0.5rem;
	}

	.sidebar-toggle[aria-expanded='true'] .hamburger {
		background: transparent;
	}

	.sidebar-toggle[aria-expanded='true'] .hamburger::before {
		top: 0;
		transform: rotate(45deg);
	}

	.sidebar-toggle[aria-expanded='true'] .hamburger::after {
		top: 0;
		transform: rotate(-45deg);
	}

	/* Scrollbar styling — no Tailwind equivalent */
	.sidebar::-webkit-scrollbar {
		width: 6px;
	}

	.sidebar::-webkit-scrollbar-track {
		background: rgb(220 252 231);
		border-radius: 3px;
	}

	.sidebar::-webkit-scrollbar-thumb {
		background: rgb(134 239 172);
		border-radius: 3px;
	}

	.sidebar::-webkit-scrollbar-thumb:hover {
		background: rgb(22 163 74);
	}

	.sidebar {
		scrollbar-width: thin;
		scrollbar-color: rgb(134 239 172) rgb(220 252 231);
	}

	/* Dark mode scrollbar — uses .dark class, not @media prefers-color-scheme */
	:global(.dark) .sidebar::-webkit-scrollbar-track {
		background: rgb(5 46 22);
	}

	:global(.dark) .sidebar::-webkit-scrollbar-thumb {
		background: rgb(74 222 128);
	}

	:global(.dark) .sidebar::-webkit-scrollbar-thumb:hover {
		background: rgb(134 239 172);
	}

	:global(.dark) .sidebar {
		scrollbar-color: rgb(74 222 128) rgb(5 46 22);
	}
</style>

<script>
	import { initSidebar } from '../../scripts/sidebar';

	initSidebar();
</script>
