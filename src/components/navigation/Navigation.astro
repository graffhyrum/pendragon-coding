---
import '../../styles/styles.css';
import { NAVIGATION_CONFIG } from '../../config/navigation';

const currentPath = Astro.url.pathname;
---
<nav>
	<ul class="flex flex-wrap items-start p-0 *:px-3 text-lg gap-2" role="list">
		{NAVIGATION_CONFIG.links.map(({ href, api, label }) => {
			const isActive = href === currentPath || (href !== '/' && (currentPath + '/').startsWith(href + '/'));
			return (
				<li class="relative group">
					<a
						href={href}
						hx-get={api}
						hx-target={NAVIGATION_CONFIG.htmx.target}
						hx-swap={NAVIGATION_CONFIG.htmx.swap}
						hx-push-url={href}
						hx-request='{"timeout": 10000}'
						aria-current={isActive ? 'page' : undefined}
						class={`relative inline-block py-1 ${isActive ? 'font-semibold text-green-700 dark:text-green-300' : ''}`}>
						{label}
						<span class={`absolute bottom-0 left-0 h-[3px] bg-green-600 dark:bg-green-400 transition-all duration-300 ${isActive ? 'w-full' : 'w-0 group-hover:w-full group-focus-within:w-full'}`}></span>
					</a>
				</li>
			);
		})}
	</ul>
</nav>

<script>
	import { initNavigation } from '../../scripts/navigation';
	initNavigation();
</script>
