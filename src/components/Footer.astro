---
const links = [
	{
		name: 'LinkedIn',
		url: 'https://www.linkedin.com/in/pendragonjoshuag/',
	},
	{
		name: 'GitHub',
		url: 'https://github.com/graffhyrum',
	},
	{
		name: 'Email Me',
		url: 'mailto:pendragon.josh@gmail.com',
	},
];
---
<footer class="flex flex-row flex-wrap justify-end items-center gap-x-4 gap-y-2 py-2 px-4 delay-400 text-green-900 dark:text-green-100">
	<p class="text-sm whitespace-nowrap">Est. 2023.</p>
	<span class="text-sm">|</span>
	<p class="text-base whitespace-nowrap">Links:</p>
	{links.map(({ name, url }) => (
		<a
			target="_blank"
			rel="noopener noreferrer"
			href={url}
			aria-label={`${name} (opens in new tab)`}
			class="text-lg whitespace-nowrap transition-all duration-300 hover:scale-110 hover:text-green-600 dark:hover:text-green-300 focus-visible:scale-110 focus-visible:text-green-600 dark:focus-visible:text-green-300"
		>
			{name}
		</a>
	))}
</footer>
