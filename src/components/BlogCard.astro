---
import { toSlug } from '../utils/slugify';
import { getExcerpt } from '../utils/excerpt';
import Card from './ui/Card.astro';

const { entry } = Astro.props;
const excerpt = getExcerpt(entry.data.description, entry.body);
---
<Card variant="long-form" maxWidth="max-w-max">
    <article id={toSlug(entry.data.title)}>
        <h3 class="text-2xl font-medium text-green-100 mt-4">{entry.data.title}</h3>
        <p class="text-sm text-green-300 my-2">{entry.data.date.toLocaleDateString('en-US', {
			year: 'numeric',
			month: 'short',
			day: 'numeric'
		})}</p>
        <p class="text-green-200 text-sm mt-2">{excerpt}</p>
    </article>
</Card>
