---
import skills from '../../content/skills';
import type { SkillCategory } from '../../types/Skill';
import Skill from '../ui/Skill.astro';

const categoryOrder: SkillCategory[] = ['QA & Testing', 'Engineering', 'Leadership'];
const grouped = new Map<SkillCategory, typeof skills>();
for (const cat of categoryOrder) {
	grouped.set(cat, skills.filter((s) => s.category === cat));
}
---

<section>
	<h2 id="top-skills">Top Skills</h2>
	<div class="skills-categories">
		{categoryOrder.map((category) => (
			<div class="skill-category-card">
				<h3 class="skill-category-heading">{category}</h3>
				<ul role="list" class="skill-category-list">
					{grouped.get(category)!.map((s) => (
						<Skill s={s} />
					))}
				</ul>
			</div>
		))}
	</div>
</section>
