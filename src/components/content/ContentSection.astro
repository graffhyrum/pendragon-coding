---
import { toSlug } from '../../utils/slugify';
import SectionList from './SectionList.astro';
import type { ContentKind } from '../../types/ContentTemplate';

interface Props {
	title: string;
	subtitle: string;
	layoutMode: 'grid' | 'single-column';
	contentKind: ContentKind;
	content: Array<{
		title: string;
		link: Array<{ title?: string; href: string }>;
		description: string;
	}>;
}

const { title, subtitle, layoutMode, contentKind, content } = Astro.props;

const sectionId = toSlug(title);
---

<section id={sectionId}>
	<h2>{title}</h2>
	<p class="text-xl">{subtitle}</p>
	<SectionList layoutMode={layoutMode} contentKind={contentKind} content={content} sectionTitle={title} />
</section>