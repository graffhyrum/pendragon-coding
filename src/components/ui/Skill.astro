---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import type { SkillData, SkillProficiency } from '../../types/Skill';

interface Props {
	s: SkillData;
}
const { s } = Astro.props;
const images = import.meta.glob<{ default: ImageMetadata }>(
	'/src/assets/*.{jpeg,jpg,png,gif,webp}',
);
if (!images[`/src/assets/${s.imagePath}`])
	throw new Error(
		`"${s.imagePath}" does not exist in glob\nList: ${Object.keys(images)}`,
	);

// Map proficiency to filled dot count for the visual indicator
const proficiencyDots: Record<SkillProficiency, number> = {
	expert: 3,
	advanced: 2,
	intermediate: 1,
};
const filled = proficiencyDots[s.proficiency];
const totalDots = 3;

// Accessible label for the proficiency level
const proficiencyLabel = `${s.proficiency} proficiency`;
---

<li class="skill-item group">
	<div class="flex items-center gap-3 min-w-0">
		<Image
			src={images[`/src/assets/${s.imagePath}`]()}
			alt={s.img_alt}
			class="w-10 h-10 object-contain shrink-0 transition-transform duration-300 group-hover:rotate-12 group-hover:scale-110 group-focus-within:rotate-12 group-focus-within:scale-110"
		/>
		<p class="text-base m-0 truncate">
			{s.skill_doc_link ? <a href={s.skill_doc_link}>{s.title}</a> : s.title}
		</p>
	</div>
	<div class="flex items-center gap-1" role="img" aria-label={proficiencyLabel} title={proficiencyLabel}>
		{Array.from({ length: totalDots }).map((_, i) => (
			<span
				class:list={[
					'w-2 h-2 rounded-full transition-colors duration-300',
					i < filled
						? 'bg-green-400 group-hover:bg-green-300'
						: 'bg-green-900/40 group-hover:bg-green-800/40',
				]}
			/>
		))}
	</div>
</li>
