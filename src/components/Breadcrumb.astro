---
interface Crumb {
	label: string;
	href?: string;
}

interface Props {
	crumbs: Crumb[];
}

const { crumbs } = Astro.props;
---

<nav aria-label="Breadcrumb" class="mt-4 mb-2 text-sm">
	<ol class="flex items-center gap-1 list-none p-0 m-0">
		{crumbs.map((crumb, index) => {
			const isLast = index === crumbs.length - 1;
			return (
				<li class="flex items-center gap-1">
					{index > 0 && <span class="text-green-500 dark:text-green-600" aria-hidden="true">&gt;</span>}
					{isLast ? (
						<span class="text-green-800 dark:text-green-400" aria-current="page">{crumb.label}</span>
					) : (
						<a href={crumb.href} class="text-green-900 dark:text-green-400 hover:text-green-800 dark:hover:text-green-300 underline underline-offset-2">{crumb.label}</a>
					)}
				</li>
			);
		})}
	</ol>
</nav>
