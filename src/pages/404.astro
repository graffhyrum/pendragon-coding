---
import BaseLayout from '../layouts/BaseLayout.astro';

const pageTitle = 'Page Not Found';
---
<BaseLayout pageTitle={pageTitle}>
	<section class="page-404-hero flex flex-col items-center justify-center text-center py-16 px-4">
		<h1 class="text-8xl font-bold text-green-700 dark:text-green-400 mb-4">404</h1>
		<h2 class="text-3xl font-semibold mb-4 text-gray-900 dark:text-gray-100">Page Not Found</h2>
		<p class="text-xl max-w-lg mb-8 text-gray-900 dark:text-gray-100">
			The page you're looking for doesn't exist or has been moved.
			Here are some places you might want to visit instead:
		</p>
		<div class="flex flex-wrap gap-4 justify-center">
			<a
				href="/"
				class="bg-green-700 hover:bg-green-600 text-white px-6 py-3 rounded-lg font-semibold transition-all duration-200 no-underline"
			>
				← Back to Home
			</a>
			<a
				href="/myWork/"
				class="border-2 border-green-700 dark:border-green-400 text-green-900 dark:text-green-400 hover:bg-green-700 hover:text-white dark:hover:bg-green-400 dark:hover:text-green-950 px-6 py-3 rounded-lg font-semibold transition-all duration-200 no-underline"
			>
				View My Work →
			</a>
			<a
				href="/blog/"
				class="border-2 border-green-700 dark:border-green-400 text-green-900 dark:text-green-400 hover:bg-green-700 hover:text-white dark:hover:bg-green-400 dark:hover:text-green-950 px-6 py-3 rounded-lg font-semibold transition-all duration-200 no-underline"
			>
				Read the Blog →
			</a>
		</div>
	</section>
</BaseLayout>
