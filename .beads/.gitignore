# SQLite database (managed by br, not git)
*.db
*.db?*
*.db-journal
*.db-wal
*.db-shm

# Runtime files
sync-state.json
last-touched
.sync.lock
export-state/

# Local version tracking
.local_version

# Worktree redirect file (contains relative path to main repo's .beads/)
redirect

# Ephemeral store (SQLite - intentionally not versioned)
ephemeral.sqlite3
ephemeral.sqlite3-journal
ephemeral.sqlite3-wal
ephemeral.sqlite3-shm

# br history (local shell history, not shared)
.br_history/

# Legacy Dolt artifacts (safe to remove after migration)
dolt/
dolt-server.*
dolt-access.lock
bd.sock
bd.sock.startlock
daemon.lock
daemon.log
daemon-*.log.gz
daemon.pid
