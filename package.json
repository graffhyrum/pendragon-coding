{
	"name": "pendragon-coding",
	"version": "2.6.1",
	"type": "module",
	"scripts": {
		"dev": "bunx astro dev",
		"start": "bunx astro dev",
		"typecheck": "tsgo --noEmit",
		"prebuild": "bun typecheck && bunx astro check",
		"build": "bunx astro build",
		"preview": "bunx astro preview",
		"astro": "bunx astro",
		"add_changeset": "bunx changeset",
		"version": "bunx changeset version",
		"format": "bunx oxfmt .",
		"lint": "bunx oxlint --ignore-path .gitignore --fix .",
		"check": "bunx oxlint --ignore-path .gitignore --fix . && bunx oxfmt .",
		"test": "bun test",
		"test:watch": "bun test --watch",
		"test:coverage": "bun test --coverage",
		"test:contrast": "bunx playwright test",
		"security": "bun audit",
		"vet": "bun typecheck && bun check && bun test && bun audit --ignore GHSA-mh29-5h37-fv8m"
	},
	"dependencies": {
		"@astrojs/check": "^0.9.8"
	},
	"devDependencies": {
		"@axe-core/playwright": "^4.11.1",
		"@changesets/cli": "^2.30.0",
		"@playwright/test": "^1.58.2",
		"@tailwindcss/vite": "^4.2.2",
		"@types/bun": "^1.3.11",
		"@typescript/native-preview": "^7.0.0-dev.20260331.1",
		"astro": "^5.18.1",
		"caniuse-lite": "^1.0.30001782",
		"happy-dom": "^20.8.9",
		"oxfmt": "0.42.0",
		"oxlint": "1.57.0",
		"tailwindcss": "^4.2.2",
		"typescript": "^5.9.3"
	},
	"overrides": {
		"ajv": ">=8.18.0",
		"mdast-util-to-hast": ">=13.2.1",
		"picomatch": ">=4.0.4",
		"rollup": ">=4.59.0",
		"svgo": ">=4.0.1",
		"yaml": ">=2.8.3"
	}
}
