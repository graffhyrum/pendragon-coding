{
	"useTabs": true,
	"tabWidth": 2,
	"printWidth": 80,
	"singleQuote": true,
	"jsxSingleQuote": false,
	"quoteProps": "as-needed",
	"trailingComma": "all",
	"semi": true,
	"arrowParens": "always",
	"bracketSameLine": false,
	"bracketSpacing": true,
	"sortImports": {},
	"sortTailwindcss": {},
	"ignorePatterns": ["**/public/**/*.*", "src/styles/styles.css", "**/*.astro"]
}
